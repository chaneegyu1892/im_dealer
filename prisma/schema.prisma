generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model FinanceCompany {
  id            String       @id @default(cuid())
  name          String       @unique
  code          String       @unique
  surchargeRate Float        @default(0)
  isActive      Boolean      @default(true)
  displayOrder  Int          @default(0)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  rateConfigs   RateConfig[]
}

model RateConfig {
  id                  String         @id @default(cuid())
  financeCompanyId    String
  vehicleCode         String
  productType         String
  minVehiclePrice     Int
  maxVehiclePrice     Int
  minPriceRates       Json
  maxPriceRates       Json
  depositDiscountRate Float
  prepayAdjustRate    Float
  isActive            Boolean        @default(true)
  memo                String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  financeCompany      FinanceCompany @relation(fields: [financeCompanyId], references: [id], onDelete: Cascade)

  @@unique([financeCompanyId, vehicleCode, productType])
  @@index([vehicleCode])
}

model RankSurchargeConfig {
  id   String @id @default(cuid())
  rank Int    @unique
  rate Float
}

model Vehicle {
  id            String                @id @default(cuid())
  slug          String                @unique
  name          String
  brand         String
  category      String
  vehicleCode   String?
  basePrice     Int
  thumbnailUrl  String
  imageUrls     String[]
  surchargeRate Float                 @default(0)
  isVisible     Boolean               @default(true)
  isPopular     Boolean               @default(false)
  displayOrder  Int                   @default(0)
  description   String?
  detailedSpecs Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  exploLogs     ExplorationLog[]
  notes         OperationalNote[]
  quoteVars     QuoteVariable[]
  recConfigs     RecommendationConfig?
  recLogs        RecommendationLog[]
  trims          Trim[]
  lineups        VehicleLineup[]
  popularConfigs PopularConfig[]

  @@index([isVisible, isPopular])
  @@index([category])
  @@index([vehicleCode])
}

model Trim {
  id             String          @id @default(cuid())
  vehicleId      String
  name           String
  price          Int
  engineType     String
  fuelEfficiency Float?
  isDefault      Boolean         @default(false)
  isVisible      Boolean         @default(true)
  specs          Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  quoteVars      QuoteVariable[]
  lineupId       String?
  lineup         VehicleLineup?  @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  options        TrimOption[]
  rules          OptionRule[]

  @@index([vehicleId])
  @@index([lineupId])
}

model VehicleLineup {
  id        String   @id @default(cuid())
  vehicleId String
  name      String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trims     Trim[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
}

model TrimOption {
  id          String   @id @default(cuid())
  trimId      String
  name        String
  price       Int      @default(0)
  category    String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  description String?
  isAccessory Boolean  @default(false)
  trim                Trim                @relation(fields: [trimId], references: [id], onDelete: Cascade)
  popularConfigItems  PopularConfigItem[]
  rulesSource         OptionRule[]        @relation("SourceRule")
  rulesTarget         OptionRule[]        @relation("TargetRule")

  @@index([trimId])
}

model OptionRule {
  id             String     @id @default(cuid())
  trimId         String
  ruleType       String     // "REQUIRED" | "INCLUDED" | "CONFLICT"
  sourceOptionId String
  targetOptionId String
  trim           Trim       @relation(fields: [trimId], references: [id], onDelete: Cascade)
  sourceOption   TrimOption @relation("SourceRule", fields: [sourceOptionId], references: [id], onDelete: Cascade)
  targetOption   TrimOption @relation("TargetRule", fields: [targetOptionId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())

  @@index([trimId])
}

model PopularConfig {
  id           String              @id @default(cuid())
  vehicleId    String
  name         String
  note         String?
  displayOrder Int                 @default(0)
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  vehicle      Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  items        PopularConfigItem[]

  @@index([vehicleId])
}

model PopularConfigItem {
  id           String        @id @default(cuid())
  configId     String
  name         String
  price        Int
  trimOptionId String?
  displayOrder Int           @default(0)
  config       PopularConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  trimOption   TrimOption?   @relation(fields: [trimOptionId], references: [id])

  @@index([configId])
}

model QuoteVariable {
  id             String    @id @default(cuid())
  vehicleId      String
  trimId         String?
  contractMonths Int[]
  annualMileages Int[]
  interestRate   Float
  residualRate   Float
  commissionRate Float
  taxRate        Float     @default(0.1)
  miscCost       Int       @default(0)
  depositOptions Int[]
  prepayOptions  Int[]
  promoDiscount  Int       @default(0)
  promoNote      String?
  promoExpiry    DateTime?
  isActive       Boolean   @default(true)
  memo           String?
  updatedAt      DateTime  @updatedAt
  updatedBy      String?
  trim           Trim?     @relation(fields: [trimId], references: [id])
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, trimId])
}

model SavedQuote {
  id             String   @id @default(cuid())
  sessionId      String
  vehicleId      String
  trimId         String
  contractMonths Int
  annualMileage  Int
  depositRate    Int
  prepayRate     Int
  contractType   String
  monthlyPayment Int
  totalCost      Int
  breakdown      Json
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  @@index([sessionId])
}

model RecommendationLog {
  id                    String    @id @default(cuid())
  sessionId             String
  industry              String
  purpose               String
  budgetMin             Int
  budgetMax             Int
  paymentStyle          String
  annualMileage         Int
  returnType            String
  recommendedVehicleIds String[]
  recommendedReason     Json
  clickedVehicleId      String?
  clickedAt             DateTime?
  proceedToQuote        Boolean   @default(false)
  vehicleId             String?
  createdAt             DateTime  @default(now())
  userAgent             String?
  ipHash                String?
  vehicle               Vehicle?  @relation(fields: [vehicleId], references: [id])

  @@index([sessionId])
  @@index([createdAt])
}

model ExplorationLog {
  id        String   @id @default(cuid())
  sessionId String
  eventType String
  path      String?
  vehicleId String?
  metadata  Json?
  createdAt DateTime @default(now())
  userAgent String?
  ipHash    String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([sessionId])
  @@index([eventType, createdAt])
}

model RecommendationConfig {
  id          String   @id @default(cuid())
  vehicleId   String   @unique
  scoreMatrix Json
  highlights  String[]
  aiCaption   String?
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  updatedBy   String?
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model ContentBanner {
  id           String    @id @default(cuid())
  type         String
  title        String
  subtitle     String?
  imageUrl     String?
  ctaLabel     String?
  ctaUrl       String?
  isVisible    Boolean   @default(true)
  displayOrder Int       @default(0)
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([type, isVisible])
}

model OperationalNote {
  id        String   @id @default(cuid())
  vehicleId String?
  category  String
  content   String
  isPinned  Boolean  @default(false)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([category, isPinned])
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("operator")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
}

model CustomerVerification {
  id                String    @id @default(cuid())
  sessionId         String
  customerType      String    // "individual" | "self_employed" | "corporate"
  connectedId       String?   // Codef Connected ID
  licenseVerified   Boolean   @default(false)
  insuranceVerified Boolean   @default(false)
  bizVerified       Boolean   @default(false)
  licenseData       Json?     // 운전면허 조회 결과
  insuranceData     Json?     // 건강보험 자격득실 결과
  bizData           Json?     // 사업자등록 상태 결과
  consentedAt       DateTime
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([sessionId])
}
