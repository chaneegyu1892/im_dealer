generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model FinanceCompany {
  id            String             @id @default(cuid())
  name          String             @unique
  code          String             @unique
  surchargeRate Float              @default(0)
  isActive      Boolean            @default(true)
  displayOrder  Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  rateSheets    CapitalRateSheet[]
}

// 주별 캐피탈사 견적 입력 및 계산된 회수율 보관
model CapitalRateSheet {
  id                  String         @id @default(cuid())
  financeCompanyId    String
  trimId              String
  weekOf              DateTime       // 해당 주 시작일 (월요일 기준)
  // 가격 범위
  minVehiclePrice     Int            // 최소 차량가
  maxVehiclePrice     Int            // 최대 차량가
  // 캐피탈사 원본 견적 (최소가 기준)
  minBaseRates        Json           // {"36_10000": 500000, ...} 최소가 기준 견적
  minDepositRates     Json           // 최소가 + 보증금 10%
  minPrepayRates      Json           // 최소가 + 선납금 10%
  // 캐피탈사 원본 견적 (최대가 기준)
  maxBaseRates        Json           // {"36_10000": 540000, ...} 최대가 기준 견적
  maxDepositRates     Json           // 최대가 + 보증금 10%
  maxPrepayRates      Json           // 최대가 + 선납금 10%
  // 자동 계산 결과
  minRateMatrix       Json           // 최소가 기준 회수율 매트릭스
  maxRateMatrix       Json           // 최대가 기준 회수율 매트릭스
  depositDiscountRate Float          // 보증금 할인 회수율 (min·max 평균)
  prepayAdjustRate    Float          // 선납금 조정 회수율 (min·max 평균)
  isActive            Boolean        @default(true)
  memo                String?
  createdAt           DateTime       @default(now())
  financeCompany      FinanceCompany @relation(fields: [financeCompanyId], references: [id], onDelete: Cascade)
  trim                Trim           @relation(fields: [trimId], references: [id], onDelete: Cascade)

  @@unique([financeCompanyId, trimId, weekOf])
  @@index([financeCompanyId, trimId])
  @@index([financeCompanyId, weekOf])
  @@index([isActive])
}

model RankSurchargeConfig {
  id   String @id @default(cuid())
  rank Int    @unique
  rate Float
}

model Vehicle {
  id            String                @id @default(cuid())
  slug          String                @unique
  name          String
  brand         String
  category      String
  vehicleCode   String?
  basePrice     Int
  thumbnailUrl  String
  imageUrls     String[]
  surchargeRate Float                 @default(0)
  isVisible     Boolean               @default(true)
  isPopular     Boolean               @default(false)
  displayOrder  Int                   @default(0)
  description   String?
  tags          String[]
  detailedSpecs Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  exploLogs     ExplorationLog[]
  notes         OperationalNote[]
  quoteVars     QuoteVariable[]
  recConfigs     RecommendationConfig?
  recLogs        RecommendationLog[]
  trims          Trim[]
  lineups        VehicleLineup[]
  popularConfigs PopularConfig[]
  quoteCalcLogs  QuoteCalcLog[]

  @@index([isVisible, isPopular])
  @@index([category])
  @@index([vehicleCode])
}

model Trim {
  id             String          @id @default(cuid())
  vehicleId      String
  name           String
  price          Int
  engineType     String
  fuelEfficiency Float?
  isDefault      Boolean         @default(false)
  isVisible      Boolean         @default(true)
  specs          Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  quoteVars      QuoteVariable[]
  lineupId       String?
  lineup         VehicleLineup?  @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  options        TrimOption[]
  rules          OptionRule[]
  inventory      Inventory[]
  rateSheets     CapitalRateSheet[]

  @@index([vehicleId])
  @@index([lineupId])
}

model VehicleLineup {
  id        String   @id @default(cuid())
  vehicleId String
  name      String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trims     Trim[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
}

model TrimOption {
  id          String   @id @default(cuid())
  trimId      String
  name        String
  price       Int      @default(0)
  category    String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  description String?
  isAccessory Boolean  @default(false)
  trim                Trim                @relation(fields: [trimId], references: [id], onDelete: Cascade)
  popularConfigItems  PopularConfigItem[]
  rulesSource         OptionRule[]        @relation("SourceRule")
  rulesTarget         OptionRule[]        @relation("TargetRule")

  @@index([trimId])
}

model OptionRule {
  id             String     @id @default(cuid())
  trimId         String
  ruleType       String     // "REQUIRED" | "INCLUDED" | "CONFLICT"
  sourceOptionId String
  targetOptionId String
  trim           Trim       @relation(fields: [trimId], references: [id], onDelete: Cascade)
  sourceOption   TrimOption @relation("SourceRule", fields: [sourceOptionId], references: [id], onDelete: Cascade)
  targetOption   TrimOption @relation("TargetRule", fields: [targetOptionId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())

  @@index([trimId])
}

model PopularConfig {
  id           String              @id @default(cuid())
  vehicleId    String
  name         String
  note         String?
  displayOrder Int                 @default(0)
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  vehicle      Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  items        PopularConfigItem[]

  @@index([vehicleId])
}

model PopularConfigItem {
  id           String        @id @default(cuid())
  configId     String
  name         String
  price        Int
  trimOptionId String?
  displayOrder Int           @default(0)
  config       PopularConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  trimOption   TrimOption?   @relation(fields: [trimOptionId], references: [id])

  @@index([configId])
}

model QuoteVariable {
  id             String    @id @default(cuid())
  vehicleId      String
  trimId         String?
  contractMonths Int[]
  annualMileages Int[]
  interestRate   Float
  residualRate   Float
  commissionRate Float
  taxRate        Float     @default(0.1)
  miscCost       Int       @default(0)
  depositOptions Int[]
  prepayOptions  Int[]
  promoDiscount  Int       @default(0)
  promoNote      String?
  promoExpiry    DateTime?
  isActive       Boolean   @default(true)
  memo           String?
  updatedAt      DateTime  @updatedAt
  updatedBy      String?
  trim           Trim?     @relation(fields: [trimId], references: [id])
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, trimId])
}

model SavedQuote {
  id                    String   @id @default(cuid())
  sessionId             String
  userId                String?
  vehicleId             String
  trimId                String
  contractMonths        Int
  annualMileage         Int
  depositRate           Int
  prepayRate            Int
  contractType          String
  monthlyPayment        Int
  totalCost             Int
  breakdown             Json
  createdAt             DateTime @default(now())
  expiresAt             DateTime
  verificationSessionId String?

  @@index([sessionId])
}

model RecommendationLog {
  id                    String    @id @default(cuid())
  sessionId             String
  industry              String
  purpose               String
  budgetMin             Int
  budgetMax             Int
  paymentStyle          String
  annualMileage         Int
  returnType            String
  recommendedVehicleIds String[]
  recommendedReason     Json
  industryDetail        String?
  purposeDetail         String?
  budgetDetail          String?
  fuelPreference        String?
  clickedVehicleId      String?
  clickedAt             DateTime?
  proceedToQuote        Boolean   @default(false)
  vehicleId             String?
  createdAt             DateTime  @default(now())
  userAgent             String?
  ipHash                String?
  vehicle               Vehicle?  @relation(fields: [vehicleId], references: [id])

  @@index([sessionId])
  @@index([createdAt])
}

model ExplorationLog {
  id        String   @id @default(cuid())
  sessionId String
  eventType String
  path      String?
  vehicleId String?
  metadata  Json?
  createdAt DateTime @default(now())
  userAgent String?
  ipHash    String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([sessionId])
  @@index([eventType, createdAt])
}

model QuoteCalcLog {
  id                 String   @id @default(cuid())
  sessionId          String
  userId             String?

  // ── 입력 조건 (독립 컬럼 → SQL 집계·ML 학습에 최적) ──
  vehicleId          String
  vehicleSlug        String
  trimId             String?
  optionIds          String[]
  contractMonths     Int
  annualMileage      Int
  depositRate        Float                     // 0, 10, 20, 30 등
  prepayRate         Float                     // 0, 10, 20, 30 등
  contractType       String                    // 반납형 / 인수형
  productType        String                    // 장기렌트 / 리스

  // ── 계산 결과 (독립 컬럼) ──
  resultMonthly      Int                       // 최종 월 납입금
  bestFinanceCompany String
  scenarioType       String                    // conservative / standard / aggressive

  // ── 행동 추적 ──
  clickedApply       Boolean  @default(false)  // 계약 신청 클릭 여부

  // ── 메타 ──
  deviceType         String?
  referrer           String?
  userAgent          String?
  ipHash             String?
  createdAt          DateTime @default(now())

  vehicle            Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleSlug, createdAt])
  @@index([sessionId])
  @@index([createdAt])
  @@index([scenarioType, createdAt])
}

model RecommendationConfig {
  id          String   @id @default(cuid())
  vehicleId   String   @unique
  scoreMatrix Json
  highlights  String[]
  aiCaption   String?
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  updatedBy   String?
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model ContentBanner {
  id           String    @id @default(cuid())
  type         String
  title        String
  subtitle     String?
  imageUrl     String?
  ctaLabel     String?
  ctaUrl       String?
  isVisible    Boolean   @default(true)
  displayOrder Int       @default(0)
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([type, isVisible])
}

model OperationalNote {
  id        String   @id @default(cuid())
  vehicleId String?
  category  String
  content   String
  isPinned  Boolean  @default(false)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([category, isPinned])
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("operator")
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
}

model CustomerVerification {
  id                String    @id @default(cuid())
  sessionId         String
  customerType      String
  connectedId       String?
  licenseVerified   Boolean   @default(false)
  insuranceVerified Boolean   @default(false)
  bizVerified       Boolean   @default(false)
  licenseData       Json?
  insuranceData     Json?
  bizData           Json?
  consentedAt       DateTime
  verifiedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([sessionId])
}

model Inventory {
  id            String   @id @default(cuid())
  trimId        String
  stockCount    Int      @default(0)
  location      String?
  status        String   @default("AVAILABLE") // AVAILABLE, RESERVED, SOLD
  colorExt      String?
  colorInt      String?
  vin           String?  @unique
  memo          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  trim          Trim     @relation(fields: [trimId], references: [id], onDelete: Cascade)

  @@index([trimId])
}
