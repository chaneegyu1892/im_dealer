generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model FinanceCompany {
  id            String             @id @default(cuid())
  name          String             @unique
  code          String             @unique
  surchargeRate Float              @default(0)
  // 견적서 PDF의 "시나리오별 견적 비교" 테이블에 금융사명 옆 로고로 노출. 어드민 업로드 URL.
  logoUrl       String?
  isActive      Boolean            @default(true)
  displayOrder  Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  rateSheets    CapitalRateSheet[]
  inventories   Inventory[]
}

// 주별 캐피탈사 견적 입력 및 계산된 회수율 보관
model CapitalRateSheet {
  id                  String         @id @default(cuid())
  financeCompanyId    String
  trimId              String
  productType         String         @default("장기렌트") // "장기렌트" | "리스"
  weekOf              DateTime       // 해당 주 시작일 (월요일 기준)
  // 가격 범위
  minVehiclePrice     Int            // 최소 차량가
  maxVehiclePrice     Int            // 최대 차량가
  // 캐피탈사 원본 견적 (최소가 기준)
  minBaseRates        Json           // {"36_10000": 500000, ...} 최소가 기준 견적
  minDepositRates     Json           // 최소가 + 보증금 10%
  minPrepayRates      Json           // 최소가 + 선납금 10%
  // 캐피탈사 원본 견적 (최대가 기준)
  maxBaseRates        Json           // {"36_10000": 540000, ...} 최대가 기준 견적
  maxDepositRates     Json           // 최대가 + 보증금 10%
  maxPrepayRates      Json           // 최대가 + 선납금 10%
  // 자동 계산 결과
  minRateMatrix       Json           // 최소가 기준 회수율 매트릭스
  maxRateMatrix       Json           // 최대가 기준 회수율 매트릭스
  depositDiscountRate Float          // 보증금 할인 회수율 (min·max 평균)
  prepayAdjustRate    Float          // 선납금 조정 회수율 (min·max 평균)
  isActive            Boolean        @default(true)
  memo                String?
  createdAt           DateTime       @default(now())
  financeCompany      FinanceCompany @relation(fields: [financeCompanyId], references: [id], onDelete: Cascade)
  trim                Trim           @relation(fields: [trimId], references: [id], onDelete: Cascade)

  @@unique([financeCompanyId, trimId, weekOf, productType])
  @@index([financeCompanyId, trimId])
  @@index([financeCompanyId, weekOf])
  @@index([isActive])
}

model RankSurchargeConfig {
  id   String @id @default(cuid())
  rank Int    @unique
  rate Float
}

model Brand {
  id           String   @id @default(cuid())
  name         String   @unique
  logoUrl      String?
  displayOrder Int      @default(0)
  // 인기 브랜드 그룹 플래그. 정렬에서 일반 브랜드보다 우선 표시되고,
  // 공개 페이지에서 "인기 브랜드" 섹션으로 묶어 보여줄 수 있다.
  isFeatured   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Vehicle {
  id            String                @id @default(cuid())
  slug          String                @unique
  name          String
  brand         String
  category      String
  vehicleCode   String?
  // 외부 데이터 소스 식별자 (재임포트 멱등성)
  externalId     String?              @unique
  externalSource String?              // "external" 등 출처 식별 태그
  basePrice     Int
  thumbnailUrl  String
  imageUrls     String[]
  surchargeRate Float                 @default(0)
  isVisible     Boolean               @default(true)
  isPopular     Boolean               @default(false)
  // 차량 탐색(/cars) 상단 "주목할 차량" 슬라이더 노출 플래그. isPopular(홈 인기차량)와 별개.
  isSpotlight   Boolean               @default(false)
  // 추천 자동검출 보정값. null=자동검출, true/false=운영자 강제. (AI 추천 가점용)
  slidingDoorOverride    Boolean?
  advancedSafetyOverride Boolean?
  displayOrder  Int                   @default(0)
  description   String?
  tags          String[]
  detailedSpecs Json?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  exploLogs     ExplorationLog[]
  notes         OperationalNote[]
  quoteVars     QuoteVariable[]
  recConfigs    RecommendationConfig?
  recLogs       RecommendationLog[]
  trims         Trim[]
  lineups       VehicleLineup[]
  popularConfigs PopularConfig[]
  quoteCalcLogs  QuoteCalcLog[]
  reviews        Review[]
  colors         VehicleColor[]

  @@index([isVisible, isPopular])
  @@index([isVisible, isSpotlight])
  @@index([category])
  @@index([vehicleCode])
  @@index([externalSource])
}

model Trim {
  id             String          @id @default(cuid())
  vehicleId      String
  name           String
  price          Int
  discountPrice  Int?
  // 전기차 보조금(안내용). 견적 계산에는 반영하지 않으며 화면 표기 전용. null=보조금 없음.
  evSubsidy      Int?
  engineType     String
  fuelEfficiency Float?
  isDefault      Boolean         @default(false)
  isVisible      Boolean         @default(true)
  specs          Json?
  // 외부 차량 데이터 소스 식별자 및 풍부한 메타(tm/division/displace/person/tax/spec/specoption/documents/colorPriceMap)
  externalId     String?         @unique
  detailedSpecs  Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  quoteVars      QuoteVariable[]
  lineupId       String?
  lineup         VehicleLineup?  @relation(fields: [lineupId], references: [id], onDelete: Cascade)
  vehicle        Vehicle         @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  options        TrimOption[]
  rules          OptionRule[]
  inventory      Inventory[]
  rateSheets     CapitalRateSheet[]

  @@index([vehicleId])
  @@index([lineupId])
}

model VehicleLineup {
  id        String   @id @default(cuid())
  vehicleId String
  name      String
  // 고객 노출 여부. 같은 차량군은 기본적으로 최신 연식만 노출되며,
  // 운영자가 예외적으로 특정 연식을 숨기거나 노출하려면 이 값을 제어한다.
  isVisible Boolean  @default(true)
  // 외부 차량 데이터 소스 식별자 및 연식/엔진/가격대/연비 메타
  externalId String?  @unique
  metadata   Json?
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  trims     Trim[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
}

model TrimOption {
  id          String   @id @default(cuid())
  trimId      String
  name        String
  price       Int      @default(0)
  category    String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  description String?
  isAccessory Boolean  @default(false)
  // 고객 노출 순서(낮을수록 상단). 운영자가 어드민에서 드래그로 지정.
  displayOrder Int     @default(0)
  // 추천 배지(추천/인기/베스트 등). 관리되는 OptionBadge 목록 참조, 미지정 시 null.
  badgeId     String?
  // 외부 차량 데이터 소스 옵션 ID (트림별로 같은 옵션이 반복되므로 trimId 와 함께 unique)
  externalId  String?
  metadata    Json?    // kind/apply/guide/package/conditionFlag 등
  trim                Trim                @relation(fields: [trimId], references: [id], onDelete: Cascade)
  badge               OptionBadge?        @relation(fields: [badgeId], references: [id], onDelete: SetNull)
  popularConfigItems  PopularConfigItem[]
  rulesSource         OptionRule[]        @relation("SourceRule")
  rulesTarget         OptionRule[]        @relation("TargetRule")

  @@unique([trimId, externalId])
  @@index([trimId])
  @@index([badgeId])
}

// 옵션 추천 배지 — 운영자가 추가/수정/삭제하는 전역 라벨 목록(추천/인기/베스트 등)
model OptionBadge {
  id           String       @id @default(cuid())
  label        String       @unique
  displayOrder Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  options      TrimOption[]
}

model OptionRule {
  id             String     @id @default(cuid())
  trimId         String
  ruleType       String     // "REQUIRED" | "INCLUDED" | "CONFLICT"
  sourceOptionId String
  targetOptionId String
  trim           Trim       @relation(fields: [trimId], references: [id], onDelete: Cascade)
  sourceOption   TrimOption @relation("SourceRule", fields: [sourceOptionId], references: [id], onDelete: Cascade)
  targetOption   TrimOption @relation("TargetRule", fields: [targetOptionId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())

  @@index([trimId])
}

model PopularConfig {
  id           String              @id @default(cuid())
  vehicleId    String
  name         String
  note         String?
  displayOrder Int                 @default(0)
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  vehicle      Vehicle             @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  items        PopularConfigItem[]

  @@index([vehicleId])
}

model PopularConfigItem {
  id           String        @id @default(cuid())
  configId     String
  name         String
  price        Int
  trimOptionId String?
  displayOrder Int           @default(0)
  config       PopularConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  trimOption   TrimOption?   @relation(fields: [trimOptionId], references: [id])

  @@index([configId])
}

model QuoteVariable {
  id             String    @id @default(cuid())
  vehicleId      String
  trimId         String?
  contractMonths Int[]
  annualMileages Int[]
  interestRate   Float
  residualRate   Float
  commissionRate Float
  taxRate        Float     @default(0.1)
  miscCost       Int       @default(0)
  depositOptions Int[]
  prepayOptions  Int[]
  promoDiscount  Int       @default(0)
  promoNote      String?
  promoExpiry    DateTime?
  isActive       Boolean   @default(true)
  memo           String?
  updatedAt      DateTime  @updatedAt
  updatedBy      String?
  trim           Trim?     @relation(fields: [trimId], references: [id])
  vehicle        Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId, trimId])
}

enum QuoteStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CONVERTED
  LOST
}

enum ColorKind {
  EXTERIOR
  INTERIOR
}

model VehicleColor {
  id          String    @id @default(cuid())
  vehicleId   String
  kind        ColorKind
  name        String
  hexCode     String
  imageUrl    String?
  priceDelta  Int       @default(0)
  isDefault   Boolean   @default(false)
  sortOrder   Int       @default(0)
  // 외부 차량 데이터 소스 식별자 및 제조사 컬러 코드 (예: "WAW"), rgb2/group/호환규칙
  externalId  String?
  mfgCode     String?
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vehicle     Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  exteriorOf  SavedQuote[] @relation("SavedQuoteExteriorColor")
  interiorOf  SavedQuote[] @relation("SavedQuoteInteriorColor")

  @@unique([vehicleId, kind, externalId])
  @@index([vehicleId, kind, sortOrder])
}

model SavedQuote {
  id                    String      @id @default(cuid())
  sessionId             String
  userId                String?
  vehicleId             String
  trimId                String
  contractMonths        Int
  annualMileage         Int
  depositRate           Int
  prepayRate            Int
  contractType          String
  customerType          String      @default("individual")
  monthlyPayment        Int
  totalCost             Int
  breakdown             Json
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  expiresAt             DateTime
  deletedAt             DateTime?
  verificationSessionId String?
  customerName          String?
  phone                 String?

  quoteType             String      @default("DETAIL")  // "AI" | "DETAIL"

  // CRM 필드
  status                QuoteStatus @default(NEW)
  assigneeId            String?
  internalMemo          String?
  contactedAt           DateTime?
  convertedAt           DateTime?

  // 색상 선택
  exteriorColorId       String?
  interiorColorId       String?
  exteriorColor         VehicleColor? @relation("SavedQuoteExteriorColor", fields: [exteriorColorId], references: [id])
  interiorColor         VehicleColor? @relation("SavedQuoteInteriorColor", fields: [interiorColorId], references: [id])

  activityLogs          QuoteActivityLog[]
  reviews               Review[]
  reviewTokens          ReviewRequestToken[]

  @@index([sessionId])
  @@index([status])
  @@index([assigneeId])
  @@index([userId])
  @@index([expiresAt])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([exteriorColorId])
  @@index([interiorColorId])
}

model QuoteActivityLog {
  id         String    @id @default(cuid())
  quoteId    String
  actorId    String
  action     String
  payload    Json?
  createdAt  DateTime  @default(now())

  quote      SavedQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model RecommendationLog {
  id                    String    @id @default(cuid())
  sessionId             String
  industry              String
  purpose               String
  budgetMin             Int
  budgetMax             Int
  paymentStyle          String
  annualMileage         Int
  returnType            String
  recommendedVehicleIds String[]
  recommendedReason     Json
  // 추천 결과 전체(차량3대 + 이유 + 시나리오 가격) freeze 스냅샷.
  // 새로고침/뒤로 시 재계산·LLM 없이 그대로 반환. null = 옛 로그(재계산 폴백).
  result                Json?
  industryDetail        String?
  purposeDetail         String?
  budgetDetail          String?
  fuelPreference        String?
  chargingEnvironment   String?
  residenceRegion       String?
  clickedVehicleId      String?
  clickedAt             DateTime?
  proceedToQuote        Boolean   @default(false)
  vehicleId             String?
  createdAt             DateTime  @default(now())
  userAgent             String?
  ipHash                String?
  vehicle               Vehicle?  @relation(fields: [vehicleId], references: [id])

  @@index([sessionId])
  @@index([createdAt])
}

model ExplorationLog {
  id        String   @id @default(cuid())
  sessionId String
  eventType String
  path      String?
  vehicleId String?
  metadata  Json?
  createdAt DateTime @default(now())
  userAgent String?
  ipHash    String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([sessionId])
  @@index([eventType, createdAt])
}

model QuoteCalcLog {
  id                 String   @id @default(cuid())
  sessionId          String
  userId             String?

  // ── 입력 조건 (독립 컬럼 → SQL 집계·ML 학습에 최적) ──
  vehicleId          String
  vehicleSlug        String
  vehicleName        String?
  trimId             String?
  optionIds          String[]
  contractMonths     Int
  annualMileage      Int
  depositRate        Float                     // 0, 10, 20, 30 등
  prepayRate         Float                     // 0, 10, 20, 30 등
  contractType       String                    // 반납형 / 인수형
  productType        String                    // 장기렌트 / 리스

  // ── 계산 결과 (독립 컬럼) ──
  resultMonthly      Int                       // 최종 월 납입금
  bestFinanceCompany String
  scenarioType       String                    // conservative / standard / aggressive
  // 차량가 + 옵션가가 회수율 시트 범위(min~max)를 초과한 경우 true.
  // 어드민 대시보드 "범위 초과 견적" 위젯에서 집계 — 회수율 데이터 보강 신호.
  rangeExceeded      Boolean  @default(false)

  // ── 행동 추적 ──
  clickedApply       Boolean  @default(false)  // 계약 신청 클릭 여부

  // ── 메타 ──
  deviceType         String?
  referrer           String?
  userAgent          String?
  ipHash             String?
  createdAt          DateTime @default(now())

  vehicle            Vehicle  @relation(fields: [vehicleId], references: [id])

  @@index([vehicleSlug, createdAt])
  @@index([sessionId])
  @@index([userId])
  @@index([vehicleId, createdAt(sort: Desc)])
  @@index([createdAt])
  @@index([scenarioType, createdAt])
}

model RecommendationConfig {
  id          String   @id @default(cuid())
  vehicleId   String   @unique
  scoreMatrix Json
  highlights  String[]
  aiCaption   String?
  isActive    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
  updatedBy   String?
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
}

model ContentBanner {
  id           String    @id @default(cuid())
  type         String
  title        String
  subtitle     String?
  imageUrl     String?
  ctaLabel     String?
  ctaUrl       String?
  isVisible    Boolean   @default(true)
  displayOrder Int       @default(0)
  startsAt     DateTime?
  endsAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([type, isVisible])
}

model OperationalNote {
  id        String   @id @default(cuid())
  vehicleId String?
  category  String
  content   String
  isPinned  Boolean  @default(false)
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id])

  @@index([category, isPinned])
}

model User {
  id               String    @id @default(cuid())
  supabaseId       String?   @unique  // Supabase auth user.id 와의 1:1 연결
  email            String?   // 카카오 이메일 미동의 케이스 수용 위해 nullable, unique 해제
  passwordHash     String?   // 레거시 JWT 인증 잔재. 추후 컬럼 자체 제거 예정.
  name             String
  role             String    @default("member")  // "member" | "dealer" | "staff" | "admin" | "superadmin"
  isActive         Boolean   @default(true)
  lastLoginAt      DateTime?
  phone            String?
  provider         String?   // "kakao" 등
  kakaoNickname    String?
  marketingConsent Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  auditLogs AdminAuditLog[]

  @@index([role, isActive])
  @@index([email])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actorEmail String
  action     String
  resource   String
  targetId   String?
  diff       Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId, createdAt])
  @@index([resource, targetId])
  @@index([action, createdAt])
}

model CustomerVerification {
  id                String    @id @default(cuid())
  sessionId         String
  customerType      String
  connectedId       String?
  licenseVerified   Boolean   @default(false)
  insuranceVerified Boolean   @default(false)
  bizVerified       Boolean   @default(false)
  licenseData       Json?
  insuranceData     Json?
  bizData           Json?
  consentedAt       DateTime
  verifiedAt        DateTime?
  piiPurgedAt       DateTime? // 90일 만료 cron 이 PII 컬럼을 NULL 로 비운 시각
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  documents         VerificationDocument[]

  @@index([sessionId])
}

// 간편인증으로 발급받은 공문서(PDF) 원본 저장. contentEnc 는 AES-256-GCM 암호화.
// 90일 만료 cron 이 contentEnc/docVerifyNo 를 비우고 piiPurgedAt 을 기록한다.
model VerificationDocument {
  id             String               @id @default(cuid())
  verificationId String
  verification   CustomerVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  docType        String // DocType enum 문자열 (resident_register 등)
  status         String               @default("pending") // pending | issued | failed
  fileName       String?
  mimeType       String?              @default("application/pdf")
  contentEnc     Json? // AES-256-GCM EncryptedBlob (base64 PDF)
  docVerifyNo    String? // 문서확인번호 (암호화 문자열) — 제3자 진위확인용
  failReason     String?
  issuedAt       DateTime?
  piiPurgedAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([verificationId])
}

model Review {
  id             String      @id @default(cuid())
  authorRealName String
  rating         Int
  content        String
  vehicleId      String?
  vehicle        Vehicle?    @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  savedQuoteId   String?
  savedQuote     SavedQuote? @relation(fields: [savedQuoteId], references: [id], onDelete: SetNull)
  isPublic       Boolean     @default(true)
  isBest         Boolean     @default(false)
  displayOrder   Int         @default(0)
  likeCount      Int         @default(0)
  reviewDate     DateTime    @default(now())
  imageUrls      String[]    @default([])
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  requestToken   ReviewRequestToken?
  likes          ReviewLike[]

  @@index([vehicleId, isPublic, displayOrder])
  @@index([isPublic, displayOrder])
  @@index([isPublic, isBest, displayOrder])
  @@index([isPublic, likeCount])
}

model ReviewLike {
  id        String   @id @default(cuid())
  reviewId  String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  anonId    String
  createdAt DateTime @default(now())

  @@unique([reviewId, anonId])
  @@index([reviewId])
  @@index([anonId])
}

model ReviewRequestToken {
  id           String     @id @default(cuid())
  token        String     @unique
  savedQuoteId String
  savedQuote   SavedQuote @relation(fields: [savedQuoteId], references: [id], onDelete: Cascade)
  expiresAt    DateTime
  usedAt       DateTime?
  revokedAt    DateTime?
  reviewId     String?    @unique
  review       Review?    @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  createdById  String?

  @@index([savedQuoteId])
  @@index([expiresAt])
}

model Inventory {
  id                String          @id @default(cuid())
  trimId            String
  stockCount        Int             @default(0)
  location          String?
  status            String          @default("AVAILABLE") // AVAILABLE, RESERVED, SOLD
  colorExt          String?
  colorInt          String?
  vin               String?         @unique
  memo              String?
  financeCompanyId  String?
  immediateDelivery Boolean         @default(false)
  selectedOptions   String[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  trim              Trim            @relation(fields: [trimId], references: [id], onDelete: Cascade)
  financeCompany    FinanceCompany? @relation(fields: [financeCompanyId], references: [id], onDelete: SetNull)

  @@index([trimId])
  @@index([financeCompanyId])
  @@index([status])
  @@index([updatedAt])
}

model AdminNotification {
  id        String   @id @default(cuid())
  type      String   // "NEW_QUOTE", "SYSTEM", "INQUIRY"
  title     String
  content   String
  linkUrl   String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([createdAt])
}
