# ─── Supabase ───────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Prisma (Supabase PostgreSQL) ──────────────────────
# pgbouncer 연결 (API Routes용, connection pooling)
DATABASE_URL="postgresql://postgres.xxxxx:password@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# 직접 연결 (마이그레이션용)
DIRECT_URL="postgresql://postgres.xxxxx:password@db.xxxxx.supabase.co:5432/postgres"

# ─── App ───────────────────────────────────────────────
# 운영 배포에서는 Vercel public domain을 사용:
# NEXT_PUBLIC_APP_URL=https://your-project.vercel.app
# Supabase Auth Redirect URL에도 같은 origin의 /auth/callback을 등록해야 함
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Admin Auth ────────────────────────────────────────
# Supabase 세션 기반 인증으로 전환됨. 어드민 권한은 grant-admin API로 부여.
# (prisma/seed.ts 가 부트스트랩용 어드민 레코드 생성 시 사용 — 비밀번호 로그인 X)
ADMIN_INITIAL_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=your-initial-seed-password

# ─── IP 해싱 ────────────────────────────────────────────
# IP 익명화 솔트 (최소 16자 랜덤 hex)
# 생성: openssl rand -hex 16
IP_HASH_SALT=your-ip-hash-salt

# ─── PII 암호화 ─────────────────────────────────────────
# CustomerVerification 의 면허/보험/사업자/connectedId 컬럼을 AES-256-GCM 으로 암호화.
# 키 분실 시 모든 PII 영구 복구 불가 — 시크릿 매니저(1Password 등)에 별도 백업 필수.
# 생성: openssl rand -base64 32
PII_ENCRYPTION_KEY=your-base64-32byte-key

# 90일 PII 자동 만료 cron (/api/cron/purge-pii) 호출용 Bearer 토큰
# 생성: openssl rand -base64 32
CRON_SECRET=your-cron-secret-32-chars-or-more

# ─── Codef (서류 확인 API) ─────────────────────────────
CODEF_CLIENT_ID=your-codef-client-id
CODEF_CLIENT_SECRET=your-codef-client-secret
CODEF_SANDBOX=true

# ─── Google Gemini (AI 추천 이유 생성, 서버 전용) ───────
# 주의: NEXT_PUBLIC_* 사용 금지 — 서버 API 라우트에서만 사용됨
GOOGLE_GENAI_API_KEY=your-gemini-api-key

# ─── Upstash Redis (Rate Limiting) ─────────────────────
# Upstash 대시보드에서 발급: https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── 채널톡 (고객 상담 위젯) ───────────────────────────
# 채널톡 대시보드 > 설정 > 개발자 도구 > Web SDK에서 발급
NEXT_PUBLIC_CHANNEL_TALK_PLUGIN_KEY=your-channel-talk-plugin-key

# ─── Sentry (에러 모니터링) ────────────────────────────
# 발급: https://sentry.io/settings/projects
NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/0
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=im-dealer
SENTRY_AUTH_TOKEN=your-sentry-auth-token
