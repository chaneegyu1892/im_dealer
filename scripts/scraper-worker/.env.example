# 스크래퍼 워커 환경변수 — 이 파일을 .env 로 복사해 채우세요. (.env 는 절대 커밋 금지)

# 백엔드 API 베이스 URL (로컬 개발: http://localhost:3000, 운영: https://your-app.vercel.app)
WORKER_API_BASE=http://localhost:3000

# 워커 인증 시크릿 — 백엔드의 SCRAPER_WORKER_SECRET 과 동일해야 함
SCRAPER_WORKER_SECRET=

# 자격증명 복호화 키 — 백엔드 .env 의 PII_ENCRYPTION_KEY 와 반드시 동일
PII_ENCRYPTION_KEY=

# true = 브라우저 창을 띄움(2FA/디버깅). false = headless.
SCRAPER_HEADFUL=true

# 폴링/세션연장/요청지연 (ms) — 보통 기본값으로 충분
SCRAPER_POLL_MS=5000
SCRAPER_KEEPALIVE_MS=120000
SCRAPER_REQUEST_DELAY_MS=1500

# 개발 컨테이너에서 Chromium sandbox를 사용할 수 없을 때만 true. production에서는 무시됩니다.
SCRAPER_DISABLE_SANDBOX=false

# Chromium 미다운로드 시(allowBuilds puppeteer=false) 시스템 브라우저 경로 지정.
# 예(Windows Edge): C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
# 또는 Chrome:      C:\Program Files\Google\Chrome\Application\chrome.exe
# PUPPETEER_EXECUTABLE_PATH=
